          "name": "Items - GET /items",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200 or 429\", () => {",
                  "  pm.expect([200, 429]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test(\"If 200, response has items array\", () => {",
                  "  if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.items).to.be.an(\"array\");",
                  "  }",
                  "});",
                  "",
                  "pm.test(\"If 429, Retry-After is present\", () => {",
                  "  if (pm.response.code === 429) {",
                  "    pm.expect(pm.response.headers.has(\"Retry-After\")).to.eql(true);",
                  "    const ra = Number(pm.response.headers.get(\"Retry-After\"));",
                  "    pm.expect(ra).to.be.a(\"number\");",
                  "    pm.expect(ra).to.be.above(0);",
                  "  }",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
