  "item": [
    {
      "name": "Debug Drills",
      "item": [
        {
          "name": "Webhook (200 - valid token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has ok=true\", function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.ok).to.eql(true);",
                  "});",
                  "",
                  "pm.test(\"received_bytes is a number > 0\", function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.received_bytes).to.be.a(\"number\");",
                  "  pm.expect(json.received_bytes).to.be.above(0);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set(\"bearer_token\", pm.environment.get(\"bearer_token_admin\"));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bearer_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "hello",
              "options": {
                "raw": {
                  "language": "text"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/webhook",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "webhook"
              ]
            }
          },
          "response": []
        },
