  "item": [
    {
      "name": "Webhook Receiver - POST /webhook",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has ok=true\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.ok).to.eql(true);",
              "});",
              "",
              "pm.test(\"received_bytes is a number > 0\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.received_bytes).to.be.a(\"number\");",
              "  pm.expect(json.received_bytes).to.be.above(0);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event_id\": \"evt_test_123\",\n  \"type\": \"payment.succeeded\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/webhook",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "webhook"
          ]
        }
      },
      "response": []
    }
  ]
